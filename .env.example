# Kafka configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SOURCE_TOPIC=iot_events
KAFKA_SINK_TOPIC=iot_metrics

# PostgreSQL configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=iot
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=iot_password

# Generator settings
EVENT_INTERVAL_SECONDS=1
TEMP_MIN=-10.0
TEMP_MAX=40.0
HUMIDITY_MIN=20.0
HUMIDITY_MAX=95.0

# Flink settings
FLINK_PARALLELISM=1
FLINK_WATERMARK_SECONDS=5
